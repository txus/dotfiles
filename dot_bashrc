# ~/.bashrc

# If not running interactively, don't do anything
[ -z "$PS1" ] && return

# Source the common aliases and functions
if [ -f ~/.aliases ]; then
    . ~/.aliases
fi

# Source the common aliases and functions
if [ -f ~/.bashrc.local ]; then
    . ~/.bashrc.local
fi
. "$HOME/.cargo/env"

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init bash)"; fi
